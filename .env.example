# Copie para .env.local e preencha com o projeto Supabase
# Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_public_key

# Com as duas variáveis preenchidas, o app usa Supabase.
# Sem elas, continua em localStorage (modo local).
# Nunca coloque chaves reais neste arquivo (.env.example vai para o git).
